[Unit]
Description=HN CCTV — NVR channel-health probe (drift detection + dark-alert)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-/home/hn/nvr-health/env
ExecStart=/usr/bin/python3 /home/hn/nvr-health/probe.py
TimeoutStartSec=120
StandardOutput=journal
StandardError=journal

{
  "manifest_version": 3,
  "name": "HN Purchase Portal Capture",
  "version": "1.4.0",
  "description": "Captures logged-in purchase portal sessions and runs live quote jobs for the HN Hotels purchase console.",
  "permissions": [
    "activeTab",
    "cookies",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://hnhotels.in/*",
    "https://hyperpure.com/*",
    "https://*.hyperpure.com/*",
    "https://zepto.com/*",
    "https://*.zepto.com/*",
    "https://zeptonow.com/*",
    "https://*.zeptonow.com/*",
    "https://flipkart.com/*",
    "https://*.flipkart.com/*",
    "https://swiggy.com/*",
    "https://*.swiggy.com/*",
    "https://blinkit.com/*",
    "https://*.blinkit.com/*",
    "https://amazon.in/*",
    "https://*.amazon.in/*",
    "https://bigbasket.com/*",
    "https://*.bigbasket.com/*",
    "https://jiomart.com/*",
    "https://*.jiomart.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
